digraph metrics {
  rankdir=LR; bgcolor="white";
  node [shape=box style="filled,rounded" fontname="Helvetica" fontsize=10 color="#444444" penwidth=1.2];
  edge [color="#888888" arrowsize=0.7];
  PRICE [shape=diamond style="filled" fillcolor="#d9d9d9" label="price_usd\n(price feed - external)"];
  { rank=source;
    S_TX [shape=cylinder style="filled,rounded" fillcolor="#e06666" penwidth=2 label="*_transfers"];
    S_BAL [shape=cylinder style="filled,rounded" fillcolor="#93c47d" penwidth=2 label="*_balances\n(balance + avg-birth age)"];
    S_STACKS [shape=cylinder style="filled,rounded" fillcolor="#6fa8dc" penwidth=2 label="*_stacks\n(legacy per-cohort coin model)"];
  }
  subgraph cluster_pivot {
    label="blue ONLY because total_supply = stack_circulation_20y\n(re-root total_supply on *_balances -> these drop stacks)";
    style="dashed"; color="#999999"; fontsize=10; fontcolor="#666666";
    total_supply [style="striped,filled" fillcolor="#93c47d:#6fa8dc" label="total_supply"];
    annual_inflation_rate [style="striped,filled" fillcolor="#93c47d:#6fa8dc" label="annual_inflation_rate"];
    daily_marketcap_usd [style="striped,filled" fillcolor="#93c47d:#6fa8dc" label="daily_marketcap_usd"];
    percent_of_total_supply_on_exchanges [style="striped,filled" fillcolor="#93c47d:#6fa8dc" label="percent_of_total_supply_on_exchanges"];
    fully_diluted_valuation_usd [style="striped,filled" fillcolor="#93c47d:#6fa8dc" label="fully_diluted_valuation_usd"];
    non_exchange_token_supply [style="striped,filled" fillcolor="#93c47d:#6fa8dc" label="non_exchange_token_supply"];
    bitcoin_dominance [style="striped,filled" fillcolor="#93c47d:#6fa8dc" label="bitcoin_dominance"];
  }
  age_distribution_5min_delta [style="filled,rounded" fillcolor="#6fa8dc" label="age_distribution_5min_delta\n(per-cohort coin-age deltas)"];
  stack_circulation_delta_T [style="filled,rounded" fillcolor="#6fa8dc" label="stack_circulation_delta_T"];
  stack_circulation_T [style="filled,rounded" fillcolor="#6fa8dc" label="stack_circulation_T"];
  nvt [style="filled,rounded" fillcolor="#6fa8dc" label="nvt"];
  stock_to_flow_ratio [style="filled,rounded" fillcolor="#6fa8dc" label="stock_to_flow_ratio"];
  token_velocity [style="striped,filled" fillcolor="#e06666:#6fa8dc" label="token_velocity"];
  nvt_transaction_volume [style="striped,filled" fillcolor="#e06666:#6fa8dc" label="nvt_transaction_volume"];
  stack_realized_cap_usd_delta [style="filled,rounded" fillcolor="#6fa8dc" label="stack_realized_cap_usd_delta"];
  stack_realized_cap_usd_T [style="filled,rounded" fillcolor="#6fa8dc" label="stack_realized_cap_usd_T"];
  mean_realized_price_usd_T [style="filled,rounded" fillcolor="#6fa8dc" label="mean_realized_price_usd_T"];
  realized_cap_hodl_waves_T [style="filled,rounded" fillcolor="#6fa8dc" label="realized_cap_hodl_waves_T"];
  mvrv_usd [style="filled,rounded" fillcolor="#6fa8dc" label="mvrv_usd"];
  mvrv_z [style="striped,filled" fillcolor="#93c47d:#6fa8dc" label="mvrv_z"];
  stack_age_consumed [style="filled,rounded" fillcolor="#6fa8dc" label="stack_age_consumed"];
  stack_liveliness [style="filled,rounded" fillcolor="#6fa8dc" label="stack_liveliness"];
  stack_mean_age_dollar_days [style="filled,rounded" fillcolor="#6fa8dc" label="stack_mean_age_dollar_days"];
  dormant_circulation [style="filled,rounded" fillcolor="#6fa8dc" label="dormant_circulation"];
  dormant_circulation_usd [style="filled,rounded" fillcolor="#6fa8dc" label="dormant_circulation_usd"];
  spent_coins_age_band_T [style="filled,rounded" fillcolor="#6fa8dc" label="spent_coins_age_band_T"];
  network_profit_loss [style="filled,rounded" fillcolor="#6fa8dc" label="network_profit_loss"];
  total_supply_in_profit [style="filled,rounded" fillcolor="#6fa8dc" label="total_supply_in_profit"];
  percent_of_total_supply_in_profit [style="filled,rounded" fillcolor="#6fa8dc" label="percent_of_total_supply_in_profit"];
  custom_total_supply_delta [style="filled,rounded" fillcolor="#93c47d" label="custom_total_supply_delta"];
  exchange_token_supply [style="filled,rounded" fillcolor="#93c47d" label="exchange_token_supply"];
  holders_distribution_T [style="filled,rounded" fillcolor="#93c47d" label="holders_distribution_T"];
  active_holders_distribution_T [style="filled,rounded" fillcolor="#93c47d" label="active_holders_distribution_T"];
  transaction_volume [style="filled,rounded" fillcolor="#e06666" label="transaction_volume"];
  transaction_count [style="filled,rounded" fillcolor="#e06666" label="transaction_count"];
  payment_count [style="filled,rounded" fillcolor="#e06666" label="payment_count"];
  daily_active_addresses [style="filled,rounded" fillcolor="#e06666" label="daily_active_addresses"];
  network_growth [style="filled,rounded" fillcolor="#e06666" label="network_growth"];
  whale_transaction_count_usd [style="filled,rounded" fillcolor="#e06666" label="whale_transaction_count_>usd"];
  whale_transaction_volume_usd [style="filled,rounded" fillcolor="#e06666" label="whale_transaction_volume_>usd"];
  daa_divergence [style="filled,rounded" fillcolor="#e06666" label="daa_divergence"];
  S_STACKS -> age_distribution_5min_delta;
  age_distribution_5min_delta -> stack_circulation_delta_T;
  stack_circulation_delta_T -> stack_circulation_T;
  stack_circulation_T -> nvt;
  stack_circulation_T -> stock_to_flow_ratio;
  stack_circulation_delta_T -> stock_to_flow_ratio;
  stack_circulation_T -> token_velocity;
  transaction_volume -> token_velocity;
  stack_circulation_T -> nvt_transaction_volume;
  transaction_volume -> nvt_transaction_volume;
  age_distribution_5min_delta -> stack_realized_cap_usd_delta;
  stack_realized_cap_usd_delta -> stack_realized_cap_usd_T;
  stack_circulation_T -> mean_realized_price_usd_T;
  stack_realized_cap_usd_T -> mean_realized_price_usd_T;
  stack_realized_cap_usd_T -> realized_cap_hodl_waves_T;
  mean_realized_price_usd_T -> mvrv_usd;
  stack_realized_cap_usd_T -> mvrv_z;
  daily_marketcap_usd -> mvrv_z;
  S_STACKS -> stack_age_consumed;
  stack_age_consumed -> stack_liveliness;
  age_distribution_5min_delta -> stack_mean_age_dollar_days;
  age_distribution_5min_delta -> dormant_circulation;
  dormant_circulation -> dormant_circulation_usd;
  age_distribution_5min_delta -> spent_coins_age_band_T;
  age_distribution_5min_delta -> network_profit_loss;
  age_distribution_5min_delta -> total_supply_in_profit;
  total_supply_in_profit -> percent_of_total_supply_in_profit;
  stack_circulation_T -> percent_of_total_supply_in_profit;
  S_BAL -> custom_total_supply_delta;
  custom_total_supply_delta -> total_supply;
  stack_circulation_T -> total_supply;
  total_supply -> daily_marketcap_usd;
  total_supply -> fully_diluted_valuation_usd;
  daily_marketcap_usd -> bitcoin_dominance;
  total_supply -> annual_inflation_rate;
  stack_circulation_T -> non_exchange_token_supply;
  exchange_token_supply -> non_exchange_token_supply;
  stack_circulation_T -> percent_of_total_supply_on_exchanges;
  exchange_token_supply -> percent_of_total_supply_on_exchanges;
  S_BAL -> exchange_token_supply;
  S_BAL -> holders_distribution_T;
  S_BAL -> active_holders_distribution_T;
  S_TX -> transaction_volume;
  S_TX -> transaction_count;
  S_TX -> payment_count;
  S_TX -> daily_active_addresses;
  S_TX -> network_growth;
  S_TX -> whale_transaction_count_usd;
  S_TX -> whale_transaction_volume_usd;
  daily_active_addresses -> daa_divergence;
  PRICE -> stack_realized_cap_usd_delta [style=dashed color="#d9d9d9" arrowsize=0.6];
  PRICE -> mvrv_usd [style=dashed color="#d9d9d9" arrowsize=0.6];
  PRICE -> mvrv_z [style=dashed color="#d9d9d9" arrowsize=0.6];
  PRICE -> dormant_circulation_usd [style=dashed color="#d9d9d9" arrowsize=0.6];
  PRICE -> network_profit_loss [style=dashed color="#d9d9d9" arrowsize=0.6];
  PRICE -> total_supply_in_profit [style=dashed color="#d9d9d9" arrowsize=0.6];
  PRICE -> daily_marketcap_usd [style=dashed color="#d9d9d9" arrowsize=0.6];
  PRICE -> fully_diluted_valuation_usd [style=dashed color="#d9d9d9" arrowsize=0.6];
  PRICE -> daa_divergence [style=dashed color="#d9d9d9" arrowsize=0.6];
  subgraph cluster_legend {
    label="legend"; fontsize=10; color="#cccccc";
    L_tx  [label="needs *_transfers" style="filled,rounded" fillcolor="#e06666"];
    L_bal [label="needs *_balances" style="filled,rounded" fillcolor="#93c47d"];
    L_st  [label="needs *_stacks"   style="filled,rounded" fillcolor="#6fa8dc"];
    L_mix [label="needs 2-3 sources (striped)" style="striped,filled" fillcolor="#e06666:#6fa8dc"];
    L_pr  [label="+ price feed (external)" shape=diamond style=filled fillcolor="#d9d9d9"];
    L_tx -> L_bal -> L_st -> L_mix -> L_pr [style=invis];
  }
}
